              { "type": "slider", "label": "Bereichsauswahl", "defaultValue": [15, 75], "showValueText": true }
            ]}
          ]
        },
        {
          "type": "card",
          "title": "Radio-Gruppe",
          "description": "Gegenseitig ausschließende Auswahl",
          "children": [
            { "type": "radioGroup", "defaultValue": "solid", "items": [
              { "label": "Fest", "value": "solid" },
              { "label": "Flüssig", "value": "liquid" },
              { "label": "Gasförmig", "value": "gas" }
            ]}
          ]
        },
        {
          "type": "card",
          "title": "Radio-Karten-Gruppe",
          "description": "Gegenseitig ausschließende Kartenauswahl",
          "children": [
            { "type": "stack", "direction": "vertical", "gap": "6", "children": [
              { "type": "radioCardGroup", "label": "Outline", "defaultValue": "pro", "items": [
                { "label": "Hobby", "value": "hobby" }, { "label": "Pro", "value": "pro" }, { "label": "Enterprise", "value": "enterprise" }
              ]},
              { "type": "radioCardGroup", "label": "Subtle", "variant": "subtle", "defaultValue": "monthly", "items": [
                { "label": "Monatlich", "value": "monthly" }, { "label": "Jährlich", "value": "yearly" }
              ]},
              { "type": "radioCardGroup", "label": "Surface", "variant": "surface", "defaultValue": "standard", "items": [
                { "label": "Standard", "value": "standard" }, { "label": "Express", "value": "express" }, { "label": "Übernacht", "value": "overnight", "disabled": true }
              ]},
              { "type": "radioCardGroup", "label": "Solid", "variant": "solid", "defaultValue": "dark", "items": [
                { "label": "Hell", "value": "light" }, { "label": "Dunkel", "value": "dark" }, { "label": "System", "value": "system" }
              ]}
            ]}
          ]
        },
        {
          "type": "card",
          "title": "Segment-Gruppe",
          "description": "Gleitende Auswahlsteuerung",
          "children": [
            { "type": "segmentGroup", "fitted": true, "defaultValue": "weekly", "items": [
              { "label": "Wöchentlich", "value": "weekly" }, { "label": "Monatlich", "value": "monthly" }, { "label": "Jährlich", "value": "yearly" }
            ]}
          ]
        },
        {
          "type": "card",
          "title": "Schlagwort-Feld",
          "description": "Schlagwort-Tags hinzufügen und entfernen",
          "children": [
            { "type": "tagsField", "label": "Interessen", "helperText": "Enter drücken, um ein Tag hinzuzufügen", "defaultValue": ["Hono", "Vite", "Panda"] }
          ]
        },
        {
          "type": "card",
          "title": "PIN-Feld",
          "description": "Einmalcode-Eingabe mit Einfügen und automatischem Vorwärtsspringen",
          "children": [
            { "type": "pinField", "label": "Bestätigungscode", "helperText": "Prüfen Sie Ihre E-Mail für den 6-stelligen Code", "count": 6, "otp": true, "blurOnComplete": true }
