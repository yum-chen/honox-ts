        },
        {
          "type": "card",
          "title": "Bewertungs-Gruppe",
          "description": "Sternbewertungen mit Halb-Sterne-Genauigkeit",
          "children": [
            { "type": "stack", "direction": "vertical", "align": "start", "gap": "4", "children": [
              { "type": "ratingGroup", "label": "Bewerten Sie Ihre Erfahrung", "defaultValue": 3 },
              { "type": "ratingGroup", "label": "Halb-Sterne-Genauigkeit", "allowHalf": true, "defaultValue": 3.5, "colorPalette": "blue" },
              { "type": "ratingGroup", "label": "Durchschnittsbewertung", "readOnly": true, "allowHalf": true, "defaultValue": 4.5, "colorPalette": "orange", "size": "sm" }
            ]}
          ]
        },
        {
          "type": "card",
          "title": "Feld",
          "description": "Texteingabe mit Beschriftung",
          "children": [
            { "type": "field", "label": "Benutzername", "defaultValue": "ab" }
