    {
      "type": "grid",
      "columns": "{\"base\": 1, \"md\": 2, \"lg\": 3}",
      "gap": "6",
      "children": [
        {
          "type": "card",
          "title": "Schalter-Steuerung",
          "description": "Stilvolle Umschalt-Schalter",
          "children": [
            { "type": "stack", "direction": "vertical", "align": "start", "gap": "4", "children": [
              { "type": "switch", "label": "Kleiner Schalter", "size": "sm" },
              { "type": "switch", "label": "Mittlere Interaktion", "size": "md", "checked": true },
              { "type": "switch", "label": "Große blaue Betonung", "size": "lg", "colorPalette": "blue" }
            ]}
          ]
        },
        {
          "type": "card",
          "title": "Kontrollkästchen-Gruppe",
          "description": "Unterstützt normale und unbestimmte Zustände",
          "children": [
            { "type": "stack", "direction": "vertical", "align": "start", "gap": "4", "children": [
              { "type": "checkbox", "label": "Kleines Kästchen", "size": "sm" },
              { "type": "checkbox", "label": "Unbestimmter Zustand", "size": "md", "checked": "indeterminate" },
              { "type": "checkbox", "label": "Große Interaktion", "size": "lg", "colorPalette": "green", "checked": true }
