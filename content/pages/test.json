{
  "title": "CMS Test Page",
  "content": [
    {
      "type": "heading",
      "text": "Welcome to the CMS Page",
      "size": "4xl",
      "as": "h1"
    },
    {
      "type": "text",
      "size": "lg",
      "content": "This page was rendered from a JSON file generated by Sveltia CMS."
    },
    {
      "type": "stack",
      "direction": "vertical",
      "gap": "6",
      "children": [
        {
          "type": "heading",
          "text": "Progress & Indicators",
          "size": "2xl",
          "as": "h2"
        },
        {
          "type": "progress",
          "label": "System Optimization Progress",
          "value": 65,
          "showValueText": true,
          "variant": "subtle",
          "size": "md"
        },
        {
          "type": "skeleton",
          "loading": true,
          "skeletonType": "text",
          "noOfLines": 2,
          "gap": "2"
        },
        {
          "type": "heading",
          "text": "Selection & Inputs",
          "size": "2xl",
          "as": "h2"
        },
        {
          "type": "stack",
          "direction": "horizontal",
          "gap": "8",
          "children": [
            {
              "type": "radioGroup",
              "label": "Deploy Region",
              "defaultValue": "us-east",
              "interactive": true,
              "items": [
                { "label": "US East", "value": "us-east" },
                { "label": "EU West", "value": "eu-west", "disabled": false }
              ]
            },
            {
              "type": "segmentGroup",
              "label": "Editor Mode",
              "defaultValue": "code",
              "fitted": true,
              "interactive": true,
              "items": [
                { "label": "Visual", "value": "visual" },
                { "label": "Code", "value": "code" }
              ]
            }
          ]
        },
        {
          "type": "heading",
          "text": "Sliders & Toggles",
          "size": "2xl",
          "as": "h2"
        },
        {
          "type": "slider",
          "label": "Sensitivity adjustment",
          "defaultValue": 40,
          "min": 0,
          "max": 100,
          "showValueText": true,
          "interactive": true
        },
        {
          "type": "switch",
          "label": "High availability cluster mode",
          "defaultChecked": true,
          "interactive": true
        },
        {
          "type": "heading",
          "text": "Table & Navigation",
          "size": "2xl",
          "as": "h2"
        },
        {
          "type": "paginatedTable"
        },
        {
          "type": "pagination",
          "count": 50,
          "pageSize": 10,
          "defaultPage": 2,
          "interactive": true
        },
        {
          "type": "heading",
          "text": "Fieldset & Field Controls",
          "size": "2xl",
          "as": "h2"
        },
        {
          "type": "fieldset",
          "legend": "User Identification",
          "helperText": "We need this to authenticate you.",
          "children": [
            {
              "type": "group",
              "attached": true,
              "grow": true,
              "children": [
                {
                  "type": "field",
                  "label": "Username",
                  "helperText": "At least 5 characters.",
                  "placeholder": "Enter username...",
                  "defaultValue": "developer"
                },
                {
                  "type": "button",
                  "text": "Check Availability",
                  "variant": "solid",
                  "colorPalette": "blue"
                }
              ]
            }
          ]
        },
        {
          "type": "heading",
          "text": "Card Component Showcase",
          "size": "2xl",
          "as": "h2"
        },
        {
          "type": "card",
          "title": "Main Project Card",
          "description": "Demonstrates Card with children",
          "variant": "outline",
          "children": [
            {
              "type": "stack",
              "direction": "vertical",
              "gap": "2",
              "children": [
                {
                  "type": "text",
                  "size": "md",
                  "content": "This text sits inside the card's body, alongside other nested elements."
                },
                {
                  "type": "checkbox",
                  "label": "Enable developer features",
                  "checked": true,
                  "interactive": true
                }
              ]
            }
          ]
        },
        {
          "type": "heading",
          "text": "Interactive Card & Overlays",
          "size": "2xl",
          "as": "h2"
        },
        {
          "type": "stack",
          "direction": "horizontal",
          "gap": "4",
          "children": [
            {
              "type": "menu",
              "triggerText": "Action Menu",
              "size": "md",
              "items": [
                { "type": "item", "label": "Edit Profile", "value": "edit" },
                { "type": "item", "label": "Preferences", "value": "prefs" },
                { "type": "separator" },
                { "type": "checkbox", "label": "Enable Telemetry", "value": "telemetry", "checked": true }
              ]
            },
            {
              "type": "hoverCard",
              "triggerText": "Hover for Info",
              "title": "Quick Help",
              "description": "Menus allow complex action triggers.",
              "showArrow": true
            },
            {
              "type": "popover",
              "triggerText": "Open Info Popover",
              "title": "Database status",
              "description": "Connection healthy.",
              "body": "No active issues or query degradation observed in this replica cluster.",
              "cancelText": "Acknowledge",
              "showArrow": true,
              "interactive": true
            }
          ]
        },
        {
          "type": "heading",
          "text": "Collapsible & Combobox Components",
          "size": "2xl",
          "as": "h2"
        },
        {
          "type": "collapsible",
          "trigger": "Click to expand configuration",
          "defaultOpen": false,
          "interactive": true,
          "children": [
            {
              "type": "stack",
              "direction": "vertical",
              "gap": "4",
              "children": [
                {
                  "type": "combobox",
                  "label": "Preferred Framework",
                  "placeholder": "Select a technology...",
                  "interactive": true,
                  "items": [
                    { "label": "React", "value": "react" },
                    { "label": "Svelte", "value": "svelte" },
                    { "label": "Hono", "value": "hono" }
                  ]
                }
              ]
            }
          ]
        },
        {
          "type": "heading",
          "text": "Modals & Overlays",
          "size": "2xl",
          "as": "h2"
        },
        {
          "type": "stack",
          "direction": "horizontal",
          "gap": "4",
          "children": [
            {
              "type": "dialog",
              "triggerText": "Open Settings Dialog",
              "title": "User Profile Settings",
              "description": "Update your profile information below.",
              "cancelText": "Close",
              "confirmText": "Save Changes",
              "interactive": true,
              "children": [
                {
                  "type": "checkbox",
                  "label": "Receive marketing newsletter",
                  "checked": "false",
                  "interactive": true
                }
              ]
            },
            {
              "type": "drawer",
              "triggerText": "Open Operations Drawer",
              "title": "System Logs",
              "description": "View real-time event telemetry.",
              "cancelText": "Dismiss",
              "interactive": true,
              "children": [
                {
                  "type": "badge",
                  "text": "System Ready",
                  "variant": "subtle",
                  "colorPalette": "green"
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
