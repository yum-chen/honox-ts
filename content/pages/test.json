{
  "title": "CMS Test Page",
  "content": [
    {
      "type": "heading",
      "text": "Welcome to the CMS Page",
      "as": "h1",
      "size": "4xl"
    },
    {
      "type": "text",
      "content": "This page was rendered from a JSON file generated by Sveltia CMS.",
      "size": "lg"
    },
    {
      "type": "stack",
      "direction": "vertical",
      "gap": "4",
      "children": [
        {
          "type": "heading",
          "text": "Interactive Components",
          "as": "h2",
          "size": "2xl"
        },
        {
          "type": "stack",
          "direction": "horizontal",
          "gap": "2",
          "children": [
            {
              "type": "button",
              "text": "Click Me",
              "variant": "solid",
              "colorPalette": "blue"
            },
            {
              "type": "badge",
              "text": "New",
              "variant": "subtle",
              "colorPalette": "green"
            }
          ]
        },
        {
          "type": "alert",
          "title": "Success",
          "description": "The page renderer is working correctly!",
          "status": "success",
          "variant": "surface"
        }
      ]
    }
  ]
}
