{
  "title": "Test Page",
  "content": [
    {
      "type": "heading",
      "size": "4xl",
      "text": "CMS Component Page Demo",
      "as": "h1"
    },
    {
      "type": "text",
      "size": "lg",
      "content": "This page demonstrates the power of our sveltiacms-backed nested component renderer."
    },
    {
      "type": "stack",
      "direction": "vertical",
      "gap": "6",
      "children": [
        {
          "type": "heading",
          "size": "2xl",
          "text": "1. Nested Card & Leaves",
          "as": "h2"
        },
        {
          "type": "card",
          "children": [
            {
              "type": "checkbox",
              "colorPalette": "blue",
              "label": "I agree to the Cabin Terms & Conditions",
              "checked": true
            },
            {
              "type": "button",
              "text": "Book Cabin Now",
              "variant": "solid",
              "colorPalette": "green",
              "size": "md"
            }
          ],
          "title": "Mountain Cabin Adventure",
          "description": "Experience nature in its purest form.",
          "body": "Located high in the Cascades, our cozy cabin provides a warm fire and majestic views.",
          "image": "https://images.unsplash.com/photo-1506744038136-46273834b3fb?w=800&q=80",
          "imagePosition": "top",
          "footer": ""
        },
        {
          "type": "heading",
          "size": "2xl",
          "text": "2. Collapsible Container",
          "as": "h2"
        },
        {
          "type": "collapsible",
          "children": [
            {
              "type": "alert",
              "variant": "subtle",
              "title": "Limited Spots",
              "description": "Cabins are filling up fast for the winter season!",
              "status": "warning"
            }
          ],
          "trigger": "Click to expand details",
          "showIndicator": true,
          "indicatorPlacement": "end",
          "open": false,
          "content": "Content"
        },
        {
          "type": "heading",
          "size": "2xl",
          "text": "3. Interactive Combobox",
          "as": "h2"
        },
        {
          "type": "combobox",
          "label": "Choose Your Favorite Framework",
          "placeholder": "Select a framework...",
          "items": [
            {
              "label": "HonoX",
              "value": "hono"
            },
            {
              "label": "React",
              "value": "react"
            },
            {
              "label": "Svelte",
              "value": "svelte"
            },
            {
              "label": "Vue",
              "value": "vue"
            }
          ]
        },
        {
          "type": "heading",
          "size": "2xl",
          "text": "4. Modals & Overlays",
          "as": "h2"
        },
        {
          "type": "stack",
          "direction": "horizontal",
          "gap": "4",
          "children": [
            {
              "type": "dialog",
              "title": "Terms of Service",
              "description": "Please read our terms before proceeding.",
              "body": "",
              "footer": "",
              "trigger": [
                {
                  "type": "button",
                  "text": "View Terms (Dialog)",
                  "variant": "outline"
                }
              ],
              "cancel": "",
              "confirm": "",
              "confirmText": "Accept",
              "cancelText": "Decline",
              "role": "dialog"
            },
            {
              "type": "drawer",
              "title": "Feedback Panel",
              "description": "We would love to hear from you.",
              "body": "",
              "footer": "",
              "trigger": [
                {
                  "type": "button",
                  "text": "Give Feedback (Drawer)",
                  "variant": "outline"
                }
              ],
              "cancel": "",
              "confirm": "",
              "confirmText": "Submit",
              "cancelText": "Cancel"
            }
          ]
        }
      ]
    },
    {
      "type": "drawer",
      "title": "TitleDrawer",
      "description": "Description",
      "body": "Body",
      "trigger": [
        {
          "type": "button",
          "variant": "solid",
          "text": "TriggerDrawer"
        }
      ],
      "confirmText": "",
      "cancelText": "",
      "footer": "Footer",
      "closable": true,
      "interactive": true,
      "cancel": "",
      "confirm": ""
    },
    {
      "type": "hoverCard",
      "children": [
        {
          "type": "alert",
          "title": "alert",
          "description": "desc",
          "variant": "subtle",
          "status": "info"
        }
      ],
      "title": "ttl",
      "description": "desc",
      "triggerText": "Hover me",
      "showArrow": true
    },
    {
      "type": "field",
      "children": [],
      "disabled": false,
      "label": "label",
      "helperText": "helper",
      "errorText": "error",
      "defaultValue": "123",
      "invalid": false,
      "required": true,
      "readOnly": false
    },
    {
      "type": "radioGroup",
      "label": "label",
      "defaultValue": "",
      "items": [
        {
          "label": "label1",
          "value": "value1",
          "disabled": false
        },
        {
          "label": "label2",
          "value": "value2",
          "disabled": false
        }
      ],
      "size": "md",
      "colorPalette": ""
    },
    {
      "type": "radioCardGroup",
      "label": "Plan",
      "defaultValue": "pro",
      "variant": "surface",
      "items": [
        {
          "label": "Hobby",
          "value": "hobby",
          "disabled": false
        },
        {
          "label": "Pro",
          "value": "pro",
          "disabled": false
        },
        {
          "label": "Enterprise",
          "value": "enterprise",
          "disabled": true
        }
      ],
      "colorPalette": "blue"
    },
    {
      "type": "editable",
      "label": "Project name",
      "defaultValue": "Mountain Cabin Adventure",
      "size": "md",
      "activationMode": "focus",
      "submitMode": "both"
    },
    {
      "type": "heading",
      "size": "2xl",
      "text": "5. New Component Bindings",
      "as": "h2"
    },
    {
      "type": "breadcrumb",
      "variant": "underline",
      "items": [
        {
          "label": "Home",
          "href": "/"
        },
        {
          "label": "Docs",
          "href": "/docs"
        },
        {
          "label": "Test Page"
        }
      ],
      "size": "md"
    },
    {
      "type": "datePicker",
      "label": "Check-in Date",
      "placeholder": "YYYY-MM-DD",
      "selectionMode": "single",
      "colorPalette": "blue"
    },
    {
      "type": "tagsInput",
      "label": "Amenities",
      "defaultValue": [
        "WiFi",
        "Fireplace",
        "Hot Tub"
      ]
    },
    {
      "type": "stack",
      "direction": "horizontal",
      "gap": "4",
      "children": [
        {
          "type": "loader",
          "text": "Checking availability..."
        },
        {
          "type": "spinner",
          "label": "Loading",
          "size": "lg"
        }
      ]
    },
    {
      "type": "table",
      "rows": "[{\"room\": \"Cabin Loft\", \"price\": \"$180/night\"}, {\"room\": \"Cabin Suite\", \"price\": \"$240/night\"}]",
      "variant": "plain",
      "columns": [
        {
          "header": "Room",
          "key": "room"
        },
        {
          "header": "Price",
          "key": "price",
          "align": "end"
        }
      ],
      "striped": true
    },
    {
      "type": "tooltip",
      "triggerText": "Cancellation Policy",
      "showArrow": true,
      "content": "Free cancellation up to 24 hours before check-in.",
      "placement": "top"
    },
    {
      "type": "absoluteCenter",
      "children": [
        {
          "type": "badge",
          "variant": "solid",
          "colorPalette": "purple",
          "text": "Centered Badge"
        }
      ],
      "axis": "both"
    },
    {
      "type": "splitter",
      "orientation": "horizontal",
      "panels": [
        {
          "id": "left",
          "content": [
            {
              "type": "text",
              "content": "Left panel"
            }
          ]
        },
        {
          "id": "right",
          "content": [
            {
              "type": "text",
              "content": "Right panel"
            }
          ]
        }
      ]
    },
    {
      "type": "heading",
      "size": "2xl",
      "text": "6. Layout Component",
      "as": "h2"
    },
    {
      "type": "text",
      "content": "A full page shell: header, sider, content and footer are each a list of arbitrary components. The sider + content row appears automatically when the Sider field is filled, and hides below the md breakpoint here."
    },
    {
      "type": "layout",
      "siderWidth": "sm",
      "siderHideBelow": "md",
      "header": [
        {
          "type": "stack",
          "direction": "horizontal",
          "align": "center",
          "justify": "between",
          "gap": "4",
          "children": [
            {
              "type": "heading",
              "size": "lg",
              "text": "Cabin Booking Portal",
              "as": "h3"
            },
            {
              "type": "badge",
              "variant": "subtle",
              "colorPalette": "green",
              "text": "3 cabins free"
            }
          ]
        }
      ],
      "sider": [
        {
          "type": "stack",
          "direction": "vertical",
          "gap": "2",
          "children": [
            {
              "type": "link",
              "text": "Availability",
              "href": "#"
            },
            {
              "type": "link",
              "text": "Rates",
              "href": "#"
            },
            {
              "type": "link",
              "text": "House Rules",
              "href": "#"
            }
          ]
        }
      ],
      "content": [
        {
          "type": "heading",
          "size": "xl",
          "text": "Winter Season Bookings",
          "as": "h4"
        },
        {
          "type": "text",
          "content": "Pick a cabin from the rail on the left. On a phone the rail hides (Sider Hide Below: md) and you would pair it with a disclosure menu instead."
        },
        {
          "type": "button",
          "text": "Check Availability",
          "variant": "solid",
          "colorPalette": "blue"
        }
      ],
      "footer": [
        {
          "type": "text",
          "size": "sm",
          "content": "Cabin Booking Portal — a Layout block with all four parts filled."
        }
      ]
    },
    {
      "type": "text",
      "content": "Every part is optional: the same block with only header, content and footer stacks vertically — no sider, no row."
    },
    {
      "type": "layout",
      "header": [
        {
          "type": "alert",
          "variant": "subtle",
          "status": "info",
          "title": "Header slot",
          "description": "Any component works here — this one is an Alert."
        }
      ],
      "content": [
        {
          "type": "card",
          "title": "Content slot",
          "description": "A Card inside the Layout's content field.",
          "body": "With no Sider filled in, the Layout is a simple header → content → footer column."
        }
      ],
      "footer": [
        {
          "type": "badge",
          "variant": "outline",
          "colorPalette": "purple",
          "text": "Footer slot"
        }
      ]
    }
  ]
}
