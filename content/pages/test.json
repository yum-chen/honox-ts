{
  "title": "Test Page",
  "content": [
    {
      "blockType": "heading",
      "size": "4xl",
      "text": "CMS Component Page Demo",
      "as": "h1"
    },
    {
      "blockType": "text",
      "size": "lg",
      "content": "This page demonstrates the power of our sveltiacms-backed nested component renderer."
    },
    {
      "blockType": "stack",
      "direction": "vertical",
      "gap": "6",
      "children": [
        {
          "blockType": "heading",
          "size": "2xl",
          "text": "1. Nested Card & Leaves",
          "as": "h2"
        },
        {
          "blockType": "card",
          "children": [
            {
              "blockType": "checkbox",
              "colorPalette": "blue",
              "label": "I agree to the Cabin Terms & Conditions",
              "checked": true
            },
            {
              "blockType": "button",
              "text": "Book Cabin Now",
              "variant": "solid",
              "colorPalette": "green",
              "size": "md"
            }
          ],
          "title": "Mountain Cabin Adventure",
          "description": "Experience nature in its purest form.",
          "body": "Located high in the Cascades, our cozy cabin provides a warm fire and majestic views.",
          "image": "https://images.unsplash.com/photo-1506744038136-46273834b3fb?w=800&q=80",
          "imagePosition": "top",
          "footer": ""
        },
        {
          "blockType": "heading",
          "size": "2xl",
          "text": "2. Collapsible Container",
          "as": "h2"
        },
        {
          "blockType": "collapsible",
          "children": [
            {
              "blockType": "alert",
              "variant": "subtle",
              "title": "Limited Spots",
              "description": "Cabins are filling up fast for the winter season!",
              "status": "warning"
            }
          ],
          "trigger": "Click to expand details",
          "showIndicator": true,
          "indicatorPlacement": "end",
          "open": false,
          "content": "Content"
        },
        {
          "blockType": "heading",
          "size": "2xl",
          "text": "3. Interactive Combobox",
          "as": "h2"
        },
        {
          "blockType": "combobox",
          "label": "Choose Your Favorite Framework",
          "placeholder": "Select a framework...",
          "items": [
            {
              "label": "HonoX",
              "value": "hono"
            },
            {
              "label": "React",
              "value": "react"
            },
            {
              "label": "Svelte",
              "value": "svelte"
            },
            {
              "label": "Vue",
              "value": "vue"
            }
          ]
        },
        {
          "blockType": "heading",
          "size": "2xl",
          "text": "4. Modals & Overlays",
          "as": "h2"
        },
        {
          "blockType": "stack",
          "direction": "horizontal",
          "gap": "4",
          "children": [
            {
              "blockType": "dialog",
              "title": "Terms of Service",
              "description": "Please read our terms before proceeding.",
              "body": "",
              "footer": "",
              "trigger": [
                {
                  "blockType": "button",
                  "text": "View Terms (Dialog)",
                  "variant": "outline"
                }
              ],
              "cancel": "",
              "confirm": "",
              "confirmText": "Accept",
              "cancelText": "Decline",
              "role": "dialog"
            },
            {
              "blockType": "drawer",
              "title": "Feedback Panel",
              "description": "We would love to hear from you.",
              "body": "",
              "footer": "",
              "trigger": [
                {
                  "blockType": "button",
                  "text": "Give Feedback (Drawer)",
                  "variant": "outline"
                }
              ],
              "cancel": "",
              "confirm": "",
              "confirmText": "Submit",
              "cancelText": "Cancel"
            }
          ]
        }
      ]
    },
    {
      "blockType": "drawer",
      "title": "TitleDrawer",
      "description": "Description",
      "body": "Body",
      "trigger": [
        {
          "blockType": "button",
          "variant": "solid",
          "text": "TriggerDrawer"
        }
      ],
      "confirmText": "",
      "cancelText": "",
      "footer": "Footer",
      "closable": true,
      "interactive": true,
      "cancel": "",
      "confirm": ""
    },
    {
      "blockType": "hoverCard",
      "children": [
        {
          "blockType": "alert",
          "title": "alert",
          "description": "desc",
          "variant": "subtle",
          "status": "info"
        }
      ],
      "title": "ttl",
      "description": "desc",
      "triggerText": "Hover me",
      "showArrow": true
    },
    {
      "blockType": "field",
      "children": [],
      "disabled": false,
      "label": "label",
      "helperText": "helper",
      "errorText": "error",
      "defaultValue": "123",
      "invalid": false,
      "required": true,
      "readOnly": false
    },
    {
      "blockType": "radioGroup",
      "label": "label",
      "defaultValue": "",
      "items": [
        {
          "label": "label1",
          "value": "value1",
          "disabled": false
        },
        {
          "label": "label2",
          "value": "value2",
          "disabled": false
        }
      ],
      "size": "md",
      "colorPalette": ""
    },
    {
      "blockType": "radioCardGroup",
      "label": "Plan",
      "defaultValue": "pro",
      "variant": "surface",
      "items": [
        {
          "label": "Hobby",
          "value": "hobby",
          "disabled": false
        },
        {
          "label": "Pro",
          "value": "pro",
          "disabled": false
        },
        {
          "label": "Enterprise",
          "value": "enterprise",
          "disabled": true
        }
      ],
      "colorPalette": "blue"
    },
    {
      "blockType": "editable",
      "label": "Project name",
      "placeholder": "",
      "defaultValue": "Mountain Cabin Adventure",
      "size": "md",
      "activationMode": "focus",
      "submitMode": "both"
    },
    {
      "blockType": "heading",
      "size": "2xl",
      "text": "5. New Component Bindings",
      "as": "h2"
    },
    {
      "blockType": "breadcrumb",
      "variant": "underline",
      "items": [
        {
          "label": "Home",
          "href": "/"
        },
        {
          "label": "Docs",
          "href": "/docs"
        },
        {
          "label": "Test Page"
        }
      ],
      "size": "md"
    },
    {
      "blockType": "datePicker",
      "label": "Check-in Date",
      "placeholder": "YYYY-MM-DD",
      "selectionMode": "single",
      "colorPalette": "blue"
    },
    {
      "blockType": "tagsField",
      "label": "Amenities",
      "defaultValue": [
        "WiFi",
        "Fireplace",
        "Hot Tub"
      ]
    },
    {
      "blockType": "search",
      "placeholder": "Search posts...",
      "src": "/api/posts/search.json",
      "debounceMs": 150,
      "maxSuggestions": 5,
      "itemLabel": "posts"
    },
    {
      "blockType": "stack",
      "direction": "horizontal",
      "gap": "4",
      "children": [
        {
          "blockType": "loader",
          "text": "Checking availability..."
        },
        {
          "blockType": "spinner",
          "label": "Loading",
          "size": "lg"
        }
      ]
    },
    {
      "blockType": "table",
      "rows": "[{\"room\": \"Cabin Loft\", \"price\": \"$180/night\"}, {\"room\": \"Cabin Suite\", \"price\": \"$240/night\"}]",
      "variant": "plain",
      "columns": [
        {
          "header": "Room",
          "key": "room"
        },
        {
          "header": "Price",
          "key": "price",
          "align": "end"
        }
      ],
      "striped": true
    },
    {
      "blockType": "tooltip",
      "triggerText": "Cancellation Policy",
      "showArrow": true,
      "content": "Free cancellation up to 24 hours before check-in.",
      "placement": "top"
    },
    {
      "blockType": "absoluteCenter",
      "children": [
        {
          "blockType": "badge",
          "variant": "solid",
          "colorPalette": "purple",
          "text": "Centered Badge"
        }
      ],
      "axis": "both"
    },
    {
      "blockType": "splitter",
      "orientation": "horizontal",
      "panels": [
        {
          "id": "left",
          "content": [
            {
              "blockType": "text",
              "content": "Left panel"
            }
          ]
        },
        {
          "id": "right",
          "content": [
            {
              "blockType": "text",
              "content": "Right panel"
            }
          ]
        }
      ]
    },
    {
      "blockType": "heading",
      "size": "2xl",
      "text": "6. Layout Component",
      "as": "h2"
    },
    {
      "blockType": "text",
      "content": "A full page shell: header, sider, content and footer are each a list of arbitrary components. The sider + content row appears automatically when the Sider field is filled, and hides below the md breakpoint here."
    },
    {
      "blockType": "layout",
      "siderWidth": "sm",
      "siderHideBelow": "md",
      "header": [
        {
          "blockType": "stack",
          "direction": "horizontal",
          "align": "center",
          "justify": "between",
          "gap": "4",
          "children": [
            {
              "blockType": "heading",
              "text": "Cabin Booking Portal",
              "size": "lg",
              "as": "h3"
            },
            {
              "blockType": "badge",
              "text": "3 cabins free",
              "variant": "subtle",
              "colorPalette": "green"
            }
          ]
        }
      ],
      "sider": [
        {
          "blockType": "stack",
          "direction": "vertical",
          "gap": "2",
          "children": [
            {
              "blockType": "link",
              "children": [
                {
                  "blockType": "text",
                  "content": "Availability"
                }
              ],
              "href": "#"
            },
            {
              "blockType": "link",
              "children": [
                {
                  "blockType": "text",
                  "content": "Rates"
                }
              ],
              "href": "#"
            },
            {
              "blockType": "link",
              "children": [
                {
                  "blockType": "text",
                  "content": "House Rules"
                }
              ],
              "href": "#"
            }
          ]
        }
      ],
      "content": [
        {
          "blockType": "heading",
          "size": "xl",
          "text": "Winter Season Bookings",
          "as": "h4"
        },
        {
          "blockType": "text",
          "content": "Pick a cabin from the rail on the left. On a phone the rail hides (Sider Hide Below: md) and you would pair it with a disclosure menu instead."
        },
        {
          "blockType": "button",
          "variant": "solid",
          "colorPalette": "blue",
          "text": "Check Availability"
        }
      ],
      "footer": [
        {
          "blockType": "text",
          "size": "sm",
          "content": "Cabin Booking Portal — a Layout block with all four parts filled."
        }
      ]
    },
    {
      "blockType": "text",
      "content": "Every part is optional: the same block with only header, content and footer stacks vertically — no sider, no row."
    },
    {
      "blockType": "layout",
      "header": [
        {
          "blockType": "alert",
          "title": "Header slot",
          "description": "Any component works here — this one is an Alert.",
          "variant": "subtle",
          "status": "info"
        }
      ],
      "content": [
        {
          "blockType": "card",
          "title": "Content slot",
          "description": "A Card inside the Layout's content field.",
          "body": "With no Sider filled in, the Layout is a simple header → content → footer column."
        }
      ],
      "footer": [
        {
          "blockType": "badge",
          "variant": "outline",
          "colorPalette": "purple",
          "text": "Footer slot"
        }
      ]
    },
    {
      "blockType": "heading",
      "size": "2xl",
      "text": "7. Nested Tabs Component",
      "as": "h2"
    },
    {
      "blockType": "tabs",
      "variant": "enclosed",
      "items": [
        {
          "label": "🏡 Included Amenities",
          "value": "amenities",
          "content": [
            {
              "blockType": "text",
              "content": "Our high-end mountain cabin offers a full array of resort-level comforts."
            },
            {
              "blockType": "stack",
              "direction": "horizontal",
              "gap": "2",
              "children": [
                {
                  "blockType": "badge",
                  "colorPalette": "green",
                  "text": "WiFi 6"
                },
                {
                  "blockType": "badge",
                  "colorPalette": "blue",
                  "text": "Hot Tub"
                },
                {
                  "blockType": "badge",
                  "colorPalette": "orange",
                  "text": "Fireplace"
                }
              ]
            }
          ]
        },
        {
          "label": "💳 Flexible Rates",
          "value": "rates",
          "content": [
            {
              "blockType": "text",
              "content": "Select the reservation tier that best matches your vacation plans."
            },
            {
              "blockType": "radioCardGroup",
              "variant": "outline",
              "label": "Reservation Class",
              "items": [
                {
                  "label": "Weekday Pass — $150/night",
                  "value": "weekday"
                },
                {
                  "label": "Weekend Escape — $220/night",
                  "value": "weekend"
                }
              ],
              "defaultValue": "weekend"
            }
          ]
        }
      ],
      "size": "md"
    },
    {
      "blockType": "heading",
      "size": "2xl",
      "text": "8. Remaining Component Bindings",
      "as": "h2"
    },
    {
      "blockType": "text",
      "content": "Every remaining CMS-bound leaf component gets a live example here, so each renderer is exercised at least once."
    },
    {
      "blockType": "group",
      "children": [
        {
          "blockType": "button",
          "variant": "outline",
          "text": "Weekday"
        },
        {
          "blockType": "button",
          "variant": "outline",
          "text": "Weekend"
        },
        {
          "blockType": "button",
          "variant": "outline",
          "text": "Holiday"
        }
      ],
      "attached": true,
      "orientation": "horizontal"
    },
    {
      "blockType": "stack",
      "direction": "horizontal",
      "align": "center",
      "gap": "6",
      "children": [
        {
          "blockType": "icon",
          "size": "lg",
          "svg": "<path d=\"M12 2l3.09 6.26L22 9.27l-5 4.87L18.18 21 12 17.77 5.82 21 7 14.14l-5-4.87 6.91-1.01L12 2z\" />",
          "ariaLabel": "Featured cabin"
        },
        {
          "blockType": "select",
          "label": "Cabin Size",
          "placeholder": "Choose a size",
          "items": [
            {
              "label": "Cozy (2 guests)",
              "value": "cozy"
            },
            {
              "label": "Family (4 guests)",
              "value": "family"
            },
            {
              "label": "Group (8 guests)",
              "value": "group"
            }
          ]
        },
        {
          "blockType": "segmentGroup",
          "label": "Stay Length",
          "defaultValue": "weekend",
          "items": [
            {
              "label": "1 Night",
              "value": "night"
            },
            {
              "label": "Weekend",
              "value": "weekend"
            },
            {
              "label": "Week",
              "value": "week"
            }
          ]
        }
      ]
    },
    {
      "blockType": "stack",
      "direction": "horizontal",
      "align": "center",
      "gap": "6",
      "children": [
        {
          "blockType": "switch",
          "label": "Pet friendly only",
          "colorPalette": "green"
        },
        {
          "blockType": "slider",
          "label": "Max Budget ($/night)",
          "defaultValue": 220,
          "colorPalette": "blue",
          "min": 50,
          "max": 500,
          "showValueText": true,
          "step": 10
        },
        {
          "blockType": "progress",
          "label": "Cabins Booked",
          "colorPalette": "purple",
          "value": 65,
          "showValueText": true
        }
      ]
    },
    {
      "blockType": "pinField",
      "label": "Booking Confirmation Code",
      "helperText": "Enter the 6-digit code we texted you.",
      "variant": "outline",
      "size": "md",
      "count": 6,
      "format": "numeric",
      "otp": true
    },
    {
      "blockType": "pinField",
      "label": "Staff Access Key",
      "helperText": "Case-insensitive, 4 characters.",
      "variant": "subtle",
      "size": "lg",
      "count": 4,
      "format": "alphanumeric",
      "mask": true
    },
    {
      "blockType": "skeleton",
      "shape": "text",
      "noOfLines": 3,
      "loaded": false
    },
    {
      "blockType": "stack",
      "direction": "horizontal",
      "gap": "4",
      "children": [
        {
          "blockType": "popover",
          "title": "Flexible Cancellation",
          "description": "Free cancellation up to 48 hours before check-in.",
          "triggerText": "Cancellation Info",
          "showArrow": true,
          "closable": true
        },
        {
          "blockType": "menu",
          "triggerText": "Manage Booking",
          "items": [
            {
              "type": "item",
              "label": "Edit Booking",
              "value": "edit"
            },
            {
              "type": "separator"
            },
            {
              "type": "item",
              "label": "Cancel Booking",
              "value": "cancel"
            }
          ]
        },
        {
          "blockType": "colorPicker",
          "trigger": true,
          "label": "Accent Color",
          "defaultValue": "#3b82f6"
        }
      ]
    },
    {
      "blockType": "carousel",
      "orientation": "horizontal",
      "slides": [
        {
          "image": "https://images.unsplash.com/photo-1449158743715-0a90ebb6d2d8?w=800&q=80",
          "caption": "Mountain Cabin Adventure",
          "href": "#"
        },
        {
          "image": "https://images.unsplash.com/photo-1518602164578-cd0074062767?w=800&q=80",
          "caption": "Lakeside Retreat",
          "href": "#"
        },
        {
          "image": "https://images.unsplash.com/photo-1449824913935-59a10b8d2000?w=800&q=80",
          "caption": "Forest Hideaway",
          "href": "#"
        }
      ],
      "slidesPerPage": 1,
      "loop": true,
      "autoplayDelay": "",
      "pauseOnHover": true
    },
    {
      "blockType": "fileUpload",
      "label": "Upload ID Document",
      "name": "idDocument",
      "triggerText": "browse files",
      "accept": ".pdf,image/*",
      "maxFiles": 1,
      "dropzoneText": "Drag your ID here, or"
    },
    {
      "blockType": "heading",
      "size": "2xl",
      "text": "9. Data & Pagination",
      "as": "h2"
    },
    {
      "blockType": "paginatedTable"
    },
    {
      "blockType": "pagination",
      "count": 120,
      "pageSize": 10,
      "defaultPage": 1,
      "siblingCount": 1,
      "boundaryCount": 1
    },
    {
      "blockType": "heading",
      "size": "2xl",
      "text": "10. Form Layout: Fieldset, Grid & Textarea",
      "as": "h2"
    },
    {
      "blockType": "fieldset",
      "children": [
        {
          "blockType": "field",
          "label": "Arrival Time",
          "name": "arrivalTime",
          "placeholder": "e.g. 3:00 PM"
        },
        {
          "blockType": "textarea",
          "label": "Notes",
          "name": "notes",
          "placeholder": "Anything else we should know?",
          "rows": 4
        }
      ],
      "helperText": "Let us know about any accessibility needs or requests.",
      "legend": "Special Requests"
    },
    {
      "blockType": "grid",
      "gap": "4",
      "children": [
        {
          "blockType": "badge",
          "variant": "solid",
          "colorPalette": "green",
          "text": "WiFi"
        },
        {
          "blockType": "badge",
          "variant": "solid",
          "colorPalette": "blue",
          "text": "Hot Tub"
        },
        {
          "blockType": "badge",
          "variant": "solid",
          "colorPalette": "orange",
          "text": "Fireplace"
        }
      ],
      "columns": "3"
    }
  ]
}
