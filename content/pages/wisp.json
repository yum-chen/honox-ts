        },
        {
          "blockType": "collapsible",
          "trigger": [
            {
              "blockType": "text",
              "size": "md",
              "content": "Can I cancel anytime?"
            }
          ],
          "showIndicator": true,
          "indicatorPlacement": "end",
          "children": [
            {
              "blockType": "text",
              "size": "md",
              "content": "Anytime, from account settings — no contracts, no cancellation fees, no phone call required."
