              "title": "Book a demo",
              "description": "Tell us where to reach you and we'll follow up within one business day.",
              "confirmText": "Request Demo",
              "cancelText": "Cancel",
              "footer": [
                {
                  "blockType": "button",
                  "variant": "plain",
                  "text": "Email Us Instead",
                  "onclick": "window.location.href = 'mailto:hello@wisp.app'"
                }
              ],
              "children": [
                {
                  "blockType": "field",
                  "label": "Work email",
                  "placeholder": "you@company.com",
                  "validator": "(value) => /^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/.test(value) || \"Enter a valid work email\""
                }
              ]
            },
            {
              "blockType": "toast"
            }
          ]
        },
        {
          "blockType": "link",
          "variant": "plain",
          "children": [
            {
              "blockType": "text",
              "content": "Read customer stories"
            }
          ],
          "colorPalette": "purple",
          "href": "/customers"
        }
