            { "type": "stack", "direction": "vertical", "gap": "4", "children": [
              { "type": "slider", "label": "Curseur simple", "defaultValue": 45, "showValueText": true },
              { "type": "slider", "label": "Sélection d'intervalle", "defaultValue": [15, 75], "showValueText": true }
            ]}
          ]
        },
        {
          "type": "card",
          "title": "Groupe radio",
          "description": "Choix mutuellement exclusifs",
          "children": [
            { "type": "radioGroup", "defaultValue": "solid", "items": [
              { "label": "Solide", "value": "solid" },
              { "label": "Liquide", "value": "liquid" },
              { "label": "Gazeux", "value": "gas" }
            ]}
          ]
        },
        {
          "type": "card",
          "title": "Groupe de cartes radio",
          "description": "Choix exclusifs en style carte",
          "children": [
            { "type": "stack", "direction": "vertical", "gap": "6", "children": [
              { "type": "radioCardGroup", "label": "Outline", "defaultValue": "pro", "items": [
                { "label": "Hobby", "value": "hobby" }, { "label": "Pro", "value": "pro" }, { "label": "Entreprise", "value": "enterprise" }
              ]},
              { "type": "radioCardGroup", "label": "Subtle", "variant": "subtle", "defaultValue": "monthly", "items": [
                { "label": "Mensuel", "value": "monthly" }, { "label": "Annuel", "value": "yearly" }
              ]},
              { "type": "radioCardGroup", "label": "Surface", "variant": "surface", "defaultValue": "standard", "items": [
                { "label": "Standard", "value": "standard" }, { "label": "Express", "value": "express" }, { "label": "Le lendemain", "value": "overnight", "disabled": true }
              ]},
              { "type": "radioCardGroup", "label": "Solid", "variant": "solid", "defaultValue": "dark", "items": [
                { "label": "Clair", "value": "light" }, { "label": "Sombre", "value": "dark" }, { "label": "Système", "value": "system" }
              ]}
            ]}
          ]
        },
        {
          "type": "card",
          "title": "Groupe segmenté",
          "description": "Contrôle de sélection glissant",
          "children": [
            { "type": "segmentGroup", "fitted": true, "defaultValue": "weekly", "items": [
              { "label": "Hebdomadaire", "value": "weekly" }, { "label": "Mensuel", "value": "monthly" }, { "label": "Annuel", "value": "yearly" }
            ]}
          ]
        },
        {
          "type": "card",
          "title": "Champ d'étiquettes",
          "description": "Ajouter et retirer des étiquettes de mots-clés",
          "children": [
            { "type": "tagsField", "label": "Centres d'intérêt", "helperText": "Appuyez sur Entrée pour ajouter une étiquette", "defaultValue": ["Hono", "Vite", "Panda"] }
          ]
        },
        {
          "type": "card",
          "title": "Champ PIN",
          "description": "Saisie de code à usage unique avec collage et avance automatique",
          "children": [
            { "type": "pinField", "label": "Code de vérification", "helperText": "Consultez votre e-mail pour le code à 6 chiffres", "count": 6, "otp": true, "blurOnComplete": true }
          ]
        },
        {
          "type": "card",
          "title": "Groupe de notation",
          "description": "Notations par étoiles avec précision à demi-étoile",
          "children": [
            { "type": "stack", "direction": "vertical", "align": "start", "gap": "4", "children": [
              { "type": "ratingGroup", "label": "Évaluez votre expérience", "defaultValue": 3 },
              { "type": "ratingGroup", "label": "Précision à demi-étoile", "allowHalf": true, "defaultValue": 3.5, "colorPalette": "blue" },
              { "type": "ratingGroup", "label": "Note moyenne", "readOnly": true, "allowHalf": true, "defaultValue": 4.5, "colorPalette": "orange", "size": "sm" }
            ]}
          ]
        },
        {
          "type": "card",
          "title": "Champ",
          "description": "Saisie de texte avec libellé",
          "children": [
            { "type": "field", "label": "Nom d'utilisateur", "defaultValue": "ab" }
          ]
        },
        {
          "type": "card",
          "title": "Zone de texte",
          "description": "Saisie de texte multiligne",
          "children": [
            { "type": "textarea", "label": "Bio", "defaultValue": "Trop court" }
          ]
        }
      ]
    },

    { "type": "heading", "as": "h3", "text": "Sélecteurs complexes", "size": "xl", "style": "border-bottom:1px solid #e5e7eb;padding-bottom:0.5rem" },
    {
      "type": "grid",
      "columns": "{\"base\": 1, \"md\": 2}",
      "gap": "6",
      "children": [
        {
          "type": "card",
          "title": "Sélecteur de date",
          "description": "Sélecteurs avancés de date et d'intervalle",
