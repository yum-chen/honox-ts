    {
      "type": "stack",
      "direction": "vertical",
      "padding": "1.5rem",
      "borderRadius": "1rem",
      "boxShadow": "sm",
      "children": [
        {
          "type": "tabs",
          "variant": "enclosed",
          "size": "md",
          "items": [
            {
              "value": "features",
              "label": "⚡ Fonctionnalités clés",
              "content": [
                {
                  "type": "grid",
                  "columns": "{\"base\": 1, \"md\": 3}",
                  "gap": "6",
                  "children": [
                    { "type": "card", "title": "Extrêmement rapide", "description": "SSR par défaut avec empreinte statique minimale. Ne s'hydrate que lorsque l'interaction est nécessaire.", "children": [{ "type": "badge", "text": "Option Zero JS", "colorPalette": "green", "variant": "subtle" }] },
                    { "type": "card", "title": "Totalement accessible", "description": "Suit strictement les normes WAI-ARIA. Entièrement navigable au clavier grâce au roving tabIndex et aux états aria.", "children": [{ "type": "badge", "text": "Conforme A11y", "colorPalette": "blue", "variant": "subtle" }] },
                    { "type": "card", "title": "Design époustouflant", "description": "Transitions à indicateur glissant et mises en page pixel-perfect alignées sur les habitudes modernes.", "children": [{ "type": "badge", "text": "Panda CSS", "colorPalette": "purple", "variant": "subtle" }] }
                  ]
                }
              ]
            },
            {
              "value": "pricing",
              "label": "💎 Grilles tarifaires",
              "content": [
                {
                  "type": "grid",
                  "columns": "{\"base\": 1, \"md\": 2}",
                  "gap": "6",
                  "children": [
                    {
                      "type": "card",
                      "title": "Démarrage",
                      "description": "Parfait pour les développeurs individuels et les projets perso qui souhaitent prototyper rapidement.",
                      "children": [
                        { "type": "stack", "direction": "horizontal", "align": "baseline", "gap": "1", "children": [
                          { "type": "heading", "as": "p", "text": "$0", "size": "3xl" },
                          { "type": "text", "size": "sm", "content": "/mois" }
                        ]},
                        { "type": "button", "text": "Commencer", "variant": "outline", "colorPalette": "blue", "size": "sm" }
                      ]
                    },
                    {
                      "type": "card",
                      "title": "Pro",
                      "description": "Fonctionnalités complètes, pages illimitées, intégration d'analytique et support prioritaire dédié.",
                      "children": [
                        { "type": "stack", "direction": "horizontal", "align": "baseline", "gap": "1", "children": [
                          { "type": "heading", "as": "p", "text": "$29", "size": "3xl" },
                          { "type": "text", "size": "sm", "content": "/mois" }
                        ]},
                        { "type": "button", "text": "Passer au Pro", "variant": "solid", "colorPalette": "blue", "size": "sm" }
                      ]
                    }
                  ]
                }
              ]
            },
            {
              "value": "tech-stack",
              "label": "🛠️ Pile technologique",
              "content": [
                {
                  "type": "card",
                  "title": "Pile Web moderne",
                  "description": "Conçue de zéro pour une production prête au déploiement et une vitesse maximales.",
                  "children": [
                    { "type": "stack", "direction": "vertical", "gap": "4", "children": [
                      { "type": "stack", "direction": "horizontal", "justify": "between", "align": "center", "children": [
                        { "type": "text", "size": "sm", "content": "Méta-framework HonoX", "style": "font-weight:bold" },
                        { "type": "badge", "text": "Rapide et Server-First", "colorPalette": "orange" }
                      ]},
                      { "type": "stack", "direction": "horizontal", "justify": "between", "align": "center", "children": [
                        { "type": "text", "size": "sm", "content": "Panda CSS", "style": "font-weight:bold" },
                        { "type": "badge", "text": "CSS-in-JS sans runtime", "colorPalette": "amber" }
                      ]},
                      { "type": "stack", "direction": "horizontal", "justify": "between", "align": "center", "children": [
                        { "type": "text", "size": "sm", "content": "Outils Bun", "style": "font-weight:bold" },
                        { "type": "badge", "text": "Vitesse de nouvelle génération", "colorPalette": "red" }
                      ]}
                    ]}
                  ]
                }
              ]
            }
          ]
        }
      ]
    },

    { "type": "heading", "as": "h2", "text": "Implémentation de carrousel en vedette", "size": "3xl", "style": "text-align:center", "id": "carousel-showcase" },
    { "type": "text", "size": "md", "content": "Présentant notre implémentation Hono/JSX robuste du Slider Carousel d'Ark UI. Glissable, avec lecture automatique et totalement accessible.", "style": "text-align:center;max-width:42rem;margin:0 auto" },
    {
      "type": "grid",
      "columns": "{\"base\": 1, \"md\": 2}",
      "gap": "8",
      "children": [
        {
          "type": "card",
          "title": "Carrousel interactif avec lecture auto",
          "description": "Déclencheurs de lecture auto, points personnalisés et pause au survol.",
          "children": [
            {
              "type": "carousel",
              "colorPalette": "blue",
              "loop": true,
              "pauseOnHover": true,
              "autoplayDelay": 3000,
              "slides": [
                { "image": "https://images.unsplash.com/photo-1551288049-bebda4e38f71?w=800&q=80", "caption": "Analyses en temps réel — Pulse fournit des données et tableaux de bord en direct avec une latence de streaming sous la seconde." },
                { "image": "https://images.unsplash.com/photo-1518186285589-2f7649de83e0?w=800&q=80", "caption": "Détection par IA — la détection intelligente d'anomalies avertit votre équipe avant les pannes de production." },
                { "image": "https://images.unsplash.com/photo-1522071820081-009f0129c71c?w=800&q=80", "caption": "Espace de travail d'équipe unifié — partagez facilement des graphiques annotés et créez des espaces personnalisés." }
              ]
            }
          ]
        },
        {
          "type": "card",
          "title": "Carrousel multi-diapositives en boucle",
          "description": "Affiche 2 diapositives par page dans une grille réactive riche.",
          "children": [
            {
              "type": "carousel",
              "colorPalette": "purple",
              "loop": true,
              "slidesPerPage": 2,
              "spacing": "12px",
              "slides": [
                { "image": "https://images.unsplash.com/photo-1557683316-973673baf926?w=600&q=80", "caption": "Diapositive 1" },
                { "image": "https://images.unsplash.com/photo-1557682250-33bd709cbe85?w=600&q=80", "caption": "Diapositive 2" },
                { "image": "https://images.unsplash.com/photo-1557683311-eac922347aa1?w=600&q=80", "caption": "Diapositive 3" },
                { "image": "https://images.unsplash.com/photo-1557682224-5b8590cd9ec5?w=600&q=80", "caption": "Diapositive 4" },
                { "image": "https://images.unsplash.com/photo-1557683316-c31a9d3d0f27?w=600&q=80", "caption": "Diapositive 5" },
                { "image": "https://images.unsplash.com/photo-1557682257-2f9c37a3a5f3?w=600&q=80", "caption": "Diapositive 6" }
              ]
            }
          ]
        }
      ]
    },

    { "type": "heading", "as": "h2", "text": "Centre de composants interactif", "size": "3xl", "style": "text-align:center", "id": "hub" },
    { "type": "text", "size": "md", "content": "Explorez les fonctionnalités riches du système de composants Artefact UI, regroupées par catégorie d'usage.", "style": "text-align:center;max-width:42rem;margin:0 auto" },

    { "type": "heading", "as": "h3", "text": "Contrôles de formulaire", "size": "xl", "style": "border-bottom:1px solid #e5e7eb;padding-bottom:0.5rem" },
    {
      "type": "grid",
      "columns": "{\"base\": 1, \"md\": 2, \"lg\": 3}",
      "gap": "6",
      "children": [
        {
          "type": "card",
          "title": "Contrôle à bascule",
          "description": "Boutons bascule élégants",
          "children": [
            { "type": "stack", "direction": "vertical", "align": "start", "gap": "4", "children": [
              { "type": "switch", "label": "Bascule petite", "size": "sm" },
              { "type": "switch", "label": "Interaction moyenne", "size": "md", "checked": true },
              { "type": "switch", "label": "Grande avec accent bleu", "size": "lg", "colorPalette": "blue" }
            ]}
          ]
        },
        {
          "type": "card",
          "title": "Groupe de cases à cocher",
          "description": "Prend en charge les états normal et indéterminé",
          "children": [
            { "type": "stack", "direction": "vertical", "align": "start", "gap": "4", "children": [
              { "type": "checkbox", "label": "Case petite", "size": "sm" },
              { "type": "checkbox", "label": "État indéterminé", "size": "md", "checked": "indeterminate" },
              { "type": "checkbox", "label": "Grande interactive", "size": "lg", "colorPalette": "green", "checked": true }
            ]}
          ]
        },
        {
          "type": "card",
          "title": "Curseur",
          "description": "Valeurs numériques ajustables",
