            { "type": "stack", "direction": "vertical", "gap": "4", "children": [
              { "type": "datePicker", "label": "Choisir une date", "selectionMode": "single" },
              { "type": "datePicker", "label": "Choisir un intervalle de dates", "selectionMode": "range", "colorPalette": "purple" }
            ]}
          ]
        },
        {
          "type": "card",
          "title": "Sélection déroulante",
          "description": "Selects accessibles et comboboxes à autocomplétion",
          "children": [
            { "type": "stack", "direction": "vertical", "gap": "4", "children": [
              { "type": "select", "label": "Sélection de framework", "placeholder": "Choisir un framework", "items": [
                { "label": "React", "value": "react" }, { "label": "Solid", "value": "solid" }, { "label": "Svelte", "value": "svelte" }, { "label": "Vue", "value": "vue" }, { "label": "Hono", "value": "hono" }
              ]},
              { "type": "combobox", "label": "Combobox recherchable", "placeholder": "Tapez pour rechercher...", "items": [
                { "label": "React", "value": "react" }, { "label": "Solid", "value": "solid" }, { "label": "Svelte", "value": "svelte" }, { "label": "Vue", "value": "vue" }, { "label": "Hono", "value": "hono" }
              ]}
            ]}
          ]
        },
        {
          "type": "card",
          "title": "Sélecteur de couleur",
          "description": "Sélecteur de spectre de couleur complet",
          "children": [
            { "type": "colorPicker", "trigger": true, "defaultValue": "#3b82f6", "label": "Choisir la couleur du thème" }
          ]
