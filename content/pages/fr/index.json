        {
          "type": "card",
          "title": "Carte au survol",
          "description": "Fenêtre contextuelle d'informations au survol",
          "children": [
            { "type": "hoverCard", "triggerText": "Survolez pour les détails de l'auteur", "showArrow": true, "title": "À propos de Jules", "description": "Conceptrice UI senior et architecte front-end spécialisée dans les suites HonoX." }
          ]
        },
        {
          "type": "card",
          "title": "Contenu repliable",
          "description": "Sections accordéon fluides",
          "children": [
            { "type": "collapsible", "trigger": [{ "type": "button", "variant": "outline", "size": "sm", "text": "Basculer les détails" }], "children": [
