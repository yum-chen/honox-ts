    {
      "type": "stack",
      "direction": "vertical",
      "align": "center",
      "gap": "4",
      "padding": "3rem 1.5rem",
      "children": [
        {
          "type": "badge",
          "text": "Composants HonoX Hono/JSX",
          "size": "lg",
          "colorPalette": "blue",
          "variant": "surface"
        },
        {
          "type": "heading",
          "as": "h1",
          "text": "Un ensemble de composants magnifiquement conçus et accessibles.",
          "size": "5xl",
          "style": "text-align:center;max-width:48rem"
        },
        {
          "type": "text",
          "size": "lg",
          "content": "Un système de design complet à trois couches, construit pour HonoX, PandaCSS et Sveltia CMS. Rapide, léger et totalement accessible, aligné sur les habitudes standards des utilisateurs.",
          "style": "text-align:center;max-width:42rem"
