        {
          "type": "card",
          "title": "Téléversement de fichiers",
          "description": "Zone glisser-déposer avec règles de validation",
          "children": [
            { "type": "fileUpload", "label": "Téléverser des images", "name": "images", "accept": "image/*", "maxFiles": 2, "dropzoneText": "Glissez-déposez ou parcourez les fichiers" }
          ]
        }
      ]
    },

    { "type": "heading", "as": "h3", "text": "Superpositions & navigation", "size": "xl", "style": "border-bottom:1px solid #e5e7eb;padding-bottom:0.5rem" },
    {
      "type": "grid",
      "columns": "{\"base\": 1, \"md\": 2, \"lg\": 3}",
      "gap": "6",
      "children": [
        {
          "type": "card",
          "title": "Popover & infobulle",
          "description": "Fenêtres d'information contextuelle",
          "children": [
            { "type": "stack", "direction": "horizontal", "align": "start", "gap": "4", "children": [
              { "type": "popover", "triggerText": "Déclencher le popover", "title": "Info rapide", "body": "Les popovers sont parfaits pour afficher un contexte riche détaillé au clic.", "showArrow": true },
              { "type": "tooltip", "triggerText": "Infobulle au survol", "content": "Agréable et accessible !", "showArrow": true }
            ]}
          ]
        },
        {
          "type": "card",
          "title": "Modales & tiroirs",
          "description": "Panneaux superposés avec piège de focus",
          "children": [
            { "type": "stack", "direction": "horizontal", "align": "start", "gap": "4", "children": [
              { "type": "dialog", "trigger": [{ "type": "button", "variant": "solid", "colorPalette": "blue", "text": "Ouvrir la modale" }], "title": "Supprimer l'espace de travail", "description": "Êtes-vous absolument sûr de vouloir supprimer cet espace de travail ?", "body": "Cette action est irréversible et toutes vos données seront définitivement effacées.", "confirmText": "Supprimer", "cancelText": "Annuler" },
              { "type": "drawer", "trigger": [{ "type": "button", "variant": "outline", "text": "Ouvrir le tiroir des paramètres" }], "title": "Paramètres du projet", "description": "Configurer les propriétés de l'espace de travail", "confirmText": "Enregistrer les modifications", "cancelText": "Fermer", "children": [
                { "type": "text", "size": "sm", "content": "Gérez ici directement vos connexions de base de données, niveaux d'accès des membres et préférences de facturation." },
                { "type": "paginatedTable", "url": "/api/posts/index.json", "dataKey": "posts", "pageSize": 3, "columns": [
                  { "header": "Titre", "key": "title" }, { "header": "Auteur", "key": "author" }, { "header": "Date", "key": "date" }
                ]}
              ]}
            ]}
          ]
        },
        {
          "type": "card",
          "title": "Menus d'actions",
          "description": "Déclencheurs de listes d'actions imbricables",
          "children": [
            { "type": "dropdown", "triggerText": "Actions de l'espace de travail", "items": [
