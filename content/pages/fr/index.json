            { "type": "button", "text": "Centre de composants", "variant": "outline", "size": "lg", "onclick": "window.scrollTo({top: document.getElementById('hub').offsetTop - 80, behavior: 'smooth'})" }
          ]
        }
      ]
    },

    { "type": "heading", "as": "h2", "text": "Démonstration d'onglets", "size": "3xl", "style": "text-align:center", "id": "tabs-showcase" },
