              "label": "Mode sombre",
              "onchange": "var d=event.target.checked?'dark':'light';localStorage.setItem('theme',d);document.documentElement.dataset.theme=d;"
            },
            {
              "blockType": "script",
              "code": "(function(){var el=document.getElementById('theme-switch');if(el)el.checked=document.documentElement.dataset.theme==='dark';})();"
            },
