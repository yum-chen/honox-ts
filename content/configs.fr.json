    },
    {
      "type": "dropdown",
      "triggerText": "🌐 FR",
      "placement": "bottom-end",
      "items": [
        { "type": "item", "label": "English", "value": "en", "toggleLocale": "en" },
        { "type": "item", "label": "中文", "value": "zh", "toggleLocale": "zh" },
        { "type": "item", "label": "Español", "value": "es", "toggleLocale": "es" },
        { "type": "item", "label": "Português", "value": "pt", "toggleLocale": "pt" },
        { "type": "item", "label": "Français", "value": "fr", "toggleLocale": "fr" },
        { "type": "item", "label": "Deutsch", "value": "de", "toggleLocale": "de" }
      ]
    },
    {
      "type": "popover",
      "triggerText": "⚙ Paramètres",
      "title": "Apparence",
      "showArrow": false,
      "children": [
        {
          "type": "stack",
          "direction": "vertical",
          "gap": "0.5",
          "children": [
            {
              "type": "button",
              "text": "Clair",
              "variant": "plain",
              "size": "sm",
              "onclick": "localStorage.setItem('theme','light');document.documentElement.dataset.theme='light';"
            },
            {
              "type": "button",
              "text": "Sombre",
              "variant": "plain",
              "size": "sm",
              "onclick": "localStorage.setItem('theme','dark');document.documentElement.dataset.theme='dark';"
            },
            {
              "type": "button",
              "text": "Système",
              "variant": "plain",
              "size": "sm",
              "onclick": "localStorage.setItem('theme','system');document.documentElement.dataset.theme=window.matchMedia('(prefers-color-scheme: dark)').matches?'dark':'light';"
            }
          ]
        }
      ]
    }
  ],
