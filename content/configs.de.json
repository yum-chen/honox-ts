        {
          "blockType": "segmentGroup",
          "items": [
            {
              "value": "light",
              "label": "Hell",
              "onclick": "localStorage.setItem('theme','light');document.documentElement.dataset.theme='light';"
            },
            {
              "value": "dark",
              "label": "Dunkel",
              "onclick": "localStorage.setItem('theme','dark');document.documentElement.dataset.theme='dark';"
            },
            {
              "value": "system",
              "label": "System",
              "onclick": "localStorage.setItem('theme','system');document.documentElement.dataset.theme=window.matchMedia('(prefers-color-scheme: dark)').matches?'dark':'light';"
            }
          ]
        },
        {
          "blockType": "radioCardGroup",
          "label": "Farbpalette",
          "style": "display:grid;grid-template-columns:repeat(2,1fr);gap:0.5rem",
          "items": [
            {
              "value": "gray",
              "label": "Grau",
              "onclick": "Array.from(document.documentElement.classList).forEach(function(c){if(c.indexOf('color-palette_')===0)document.documentElement.classList.remove(c)});document.documentElement.classList.add('color-palette_gray');localStorage.setItem('colorPalette','gray');"
            },
