{
	"name": "artefact",
	"module": "src/main.ts",
	"type": "module",
	"private": true,
	"scripts": {
		"dev": "vite",
		"build": "vite build --mode client && vite build",
		"preview": "wrangler dev",
		"deploy": "bun run build && wrangler pages deploy ./dist",
		"fix": "bun run check",
		"check": "bun x @biomejs/biome check --fix .",
		"format": "bun x @biomejs/biome format --fix .",
		"lint": "bun x @biomejs/biome lint --fix .",
		"start": "bun run src/main.ts"
	},
	"dependencies": {
		"hono": "^4.12.26",
		"honox": "0.1.56"
	},
	"peerDependencies": {
		"typescript": "^5.9.3"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.0",
		"@cloudflare/workers-types": "^4.20260617.1",
		"@hono/vite-build": "^1.11.1",
		"@hono/vite-dev-server": "^0.25.3",
		"@hono/vite-ssg": "^0.3.3",
		"@tailwindcss/vite": "^4.3.1",
		"@types/bun": "latest",
		"tailwindcss": "^4.3.1",
		"vite": "^8.0.16",
		"wrangler": "^4.101.0"
	}
}
