{
	"name": "artefact",
	"module": "src/main.ts",
	"type": "module",
	"private": true,
	"scripts": {
		"prepare": "panda codegen",
		"dev": "vite",
		"build": "vite build --mode client && vite build",
		"preview": "wrangler dev",
		"deploy": "bun run build && wrangler pages deploy ./dist",
		"fix": "bun run check",
		"check": "bun x @biomejs/biome check --fix .",
		"format": "bun x @biomejs/biome format --fix .",
		"lint": "bun x @biomejs/biome lint --fix .",
		"start": "bun run src/main.ts"
	},
	"dependencies": {
		"@ark-ui/react": "^5.37.2",
		"hono": "^4.12.29",
		"honox": "0.1.56"
	},
	"peerDependencies": {
		"typescript": "^5.9.3"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.3",
		"@hono/vite-build": "^1.11.1",
		"@hono/vite-dev-server": "^0.25.3",
		"@hono/vite-ssg": "^0.3.3",
		"@pandacss/dev": "^1.11.4",
		"@types/bun": "latest",
		"autoprefixer": "^10.5.2",
		"postcss": "^8.5.16",
		"vite": "^8.1.4",
		"wrangler": "^4.110.0"
	}
}
