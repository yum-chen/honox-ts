{
	"name": "artefact",
	"module": "src/main.ts",
	"type": "module",
	"private": true,
	"scripts": {
		"dev": "vite",
		"build": "vite build --mode client && vite build --emptyOutDir false",
		"preview": "wrangler dev",
		"deploy": "bun run build && wrangler deploy",
		"fix": "bun run check",
		"check": "bun x @biomejs/biome check --fix .",
		"format": "bun x @biomejs/biome format --fix .",
		"lint": "bun x @biomejs/biome lint --fix .",
		"start": "bun run src/main.ts",
		"prepare": "panda codegen"
	},
	"dependencies": {
		"hono": "^4.12.26",
		"honox": "0.1.56",
		"js-yaml": "^4.2.0",
		"marked": "^18.0.5"
	},
	"peerDependencies": {
		"typescript": "^5.9.3"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.0",
		"@cloudflare/workers-types": "^4.20260617.1",
		"@hono/vite-dev-server": "^0.25.3",
		"@hono/vite-ssg": "^0.3.3",
		"@pandacss/dev": "^1.11.3",
		"@types/bun": "latest",
		"@types/js-yaml": "^4.0.9",
		"@types/marked": "^6.0.0",
		"autoprefixer": "^10.5.0",
		"postcss": "^8.5.15",
		"vite": "^8.0.16",
		"wrangler": "^4.101.0"
	}
}
